# PostgreSQL — injecté automatiquement par Railway
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Ton email admin (seul cet email obtient le rôle admin à l'inscription)
ADMIN_EMAIL=ton@email.com

# Clé JWT — chaîne aléatoire longue, change-la en production
JWT_SECRET=change-moi-en-production

# Resend — notifications email (optionnel)
# Crée un compte sur https://resend.com (gratuit, sans CB)
# Dashboard → API Keys → Create API Key
RESEND_API_KEY=re_xxxxxxxxxxxx

# Adresse expéditeur (optionnel — nécessite un domaine vérifié sur Resend)
# Sans domaine vérifié, laisse vide : seuls les envois vers ADMIN_EMAIL fonctionneront
FROM_EMAIL=Wishlist <notif@tondomaine.fr>

# URL publique du site (optionnel — pour les liens d'invitation corrects)
BASE_URL=https://ton-app.up.railway.app

PORT=3000
NODE_ENV=development
