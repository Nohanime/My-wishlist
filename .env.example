# Copie ce fichier en .env et remplis les valeurs

# URL PostgreSQL fournie par Railway (injectée automatiquement sur Railway)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Ton email : seul cet email aura le rôle admin
ADMIN_EMAIL=ton@email.com

# Clé secrète pour signer les JWT — mets une longue chaîne aléatoire
JWT_SECRET=change-moi-en-production-abc123xyz

# Optionnel
PORT=3000
NODE_ENV=development
