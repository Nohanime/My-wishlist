# PostgreSQL — injecté automatiquement par Railway
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Ton email admin (seul cet email a le rôle admin)
ADMIN_EMAIL=ton@email.com

# Clé JWT — chaîne aléatoire longue
JWT_SECRET=change-moi-en-production

# Resend — pour les notifications email
# Crée un compte sur https://resend.com (gratuit, pas de CB)
# Dashboard → API Keys → Create API Key
RESEND_API_KEY=re_xxxxxxxxxxxx

# URL publique du site (optionnel, pour les liens d'invitation dans les emails)
BASE_URL=https://ton-app.up.railway.app

PORT=3000
NODE_ENV=development
